{
  "name": "deepphe-visualizer-v3",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "DeepPhe Visualizer v3 - Cancer phenotype visualization and analysis",
  "dependencies": {
    "@emotion/cache": "11.10.8",
    "@emotion/react": "11.11.4",
    "@emotion/styled": "11.10.8",
    "@mui/base": "^5.0.0-beta.40-1",
    "@mui/icons-material": "5.11.16",
    "@mui/lab": "^5.0.0-alpha.177",
    "@mui/material": "^5.16.4",
    "@mui/styles": "5.16.4",
    "@mui/system": "5.16.4",
    "@mui/utils": "5.16.4",
    "@mui/x-charts": "^7.10.0",
    "@mui/x-data-grid": "^7.6.2",
    "@tanstack/react-table": "^8.21.3",
    "@upsetjs/react": "^1.11.0",
    "chroma-js": "2.4.2",
    "eslint-config-react-app": "^7.0.1",
    "html-react-parser": "^5.2.11",
    "lodash": "^4.17.21",
    "prop-types": "15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.1",
    "react-scripts": "5.0.1",
    "sass": "^1.70.0",
    "stylis": "4.1.4",
    "stylis-plugin-rtl": "2.1.1",
    "@react-buddy/ide-toolbox": "^2.4.0",
    "@react-buddy/palette-mui": "^5.0.1"
  },
  "scripts": {
    "sync:viz2-docs": "node scripts/sync-viz2-docs.mjs",
    "prestart": "npm run sync:viz2-docs",
    "prebuild": "npm run sync:viz2-docs",
    "start": "craco start",
    "build": "craco build",
    "test": "craco test",
    "eject": "react-scripts eject",
    "lint": "eslint src/",
    "lint:patient-ids": "node scripts/check-no-patient-ids.mjs",
    "lint:a11y": "eslint src/ --rule 'jsx-a11y/alt-text: error' --rule 'jsx-a11y/anchor-is-valid: error'",
    "install:clean": "rm -rf node_modules/ && rm -rf package-lock.json && npm install && npm start",
    "capture:screenshots": "node scripts/capture-screenshots.mjs",
    "test:layout-bottoms": "node scripts/test-filter-card-bottoms.mjs",
    "docs:build": "bash scripts/build-mkdocs.sh",
    "docs:pdf": "node scripts/export-pdf.mjs",
    "docs:review": "npm run capture:screenshots && npm run docs:build && npm run docs:pdf"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@craco/craco": "^7.1.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-prettier": "4.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "playwright": "^1.58.2",
    "prettier": "2.8.8",
    "react-refresh": "^0.17.0"
  },
  "overrides": {
    "svgo": "3.0.2"
  }
}
